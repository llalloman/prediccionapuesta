datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  ANALYST
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum Recommendation {
  BET
  AVOID
  WATCH
  INSUFFICIENT_DATA
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
  CASHED_OUT
}

enum RiskProfile {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

model User {
  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(USER)
  status       UserStatus  @default(ACTIVE)
  bankrolls    Bankroll[]
  bets         Bet[]
  aiAnalyses   AiAnalysis[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Team {
  id          String   @id @default(uuid())
  name        String
  country     String?
  shortName   String?
  logoUrl     String?
  fifaCode    String?
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Competition {
  id        String   @id @default(uuid())
  name      String
  season    String?
  country   String?
  type      String?
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id            String      @id @default(uuid())
  competitionId String
  homeTeamId    String
  awayTeamId    String
  startTime     DateTime
  status        MatchStatus @default(SCHEDULED)
  stage         String?
  venue         String?
  homeScore     Int?
  awayScore     Int?

  competition Competition @relation(fields: [competitionId], references: [id])
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])

  odds         Odd[]
  predictions  Prediction[]
  valueSignals ValueSignal[]
  bets         Bet[]
  aiAnalyses   AiAnalysis[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bookmaker {
  id           String   @id @default(uuid())
  name         String
  website      String?
  country      String?
  isActive     Boolean  @default(true)
  odds         Odd[]
  bets         Bet[]
  valueSignals ValueSignal[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Market {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  description  String?
  isActive     Boolean  @default(true)
  odds         Odd[]
  bets         Bet[]
  valueSignals ValueSignal[]
}

model Odd {
  id                 String   @id @default(uuid())
  matchId            String
  bookmakerId        String
  marketId           String
  selection          String
  decimalOdd         Decimal
  impliedProbability Decimal
  capturedAt         DateTime @default(now())
  isLatest           Boolean  @default(true)

  match     Match     @relation(fields: [matchId], references: [id])
  bookmaker Bookmaker @relation(fields: [bookmakerId], references: [id])
  market    Market    @relation(fields: [marketId], references: [id])

  createdAt DateTime @default(now())
}

model Prediction {
  id                 String   @id @default(uuid())
  matchId            String
  modelVersion       String
  homeWinProbability Decimal
  drawProbability    Decimal
  awayWinProbability Decimal
  over25Probability  Decimal?
  bttsProbability    Decimal?
  confidence         Decimal?
  notes              String?
  createdAt          DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
}

model ValueSignal {
  id                   String         @id @default(uuid())
  matchId              String
  marketId             String
  bookmakerId          String
  selection            String
  decimalOdd           Decimal
  bookmakerProbability Decimal
  modelProbability     Decimal
  edge                 Decimal
  expectedValue        Decimal?
  riskLevel            RiskLevel
  recommendation       Recommendation
  createdAt            DateTime @default(now())

  match     Match     @relation(fields: [matchId], references: [id])
  market    Market    @relation(fields: [marketId], references: [id])
  bookmaker Bookmaker @relation(fields: [bookmakerId], references: [id])
}

model Bankroll {
  id                 String      @id @default(uuid())
  userId             String
  initialAmount      Decimal
  currentAmount      Decimal
  currency           String      @default("USD")
  riskProfile        RiskProfile @default(CONSERVATIVE)
  maxStakePercentage Decimal     @default(1.0)
  dailyLossLimit     Decimal?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Bet {
  id              String    @id @default(uuid())
  userId          String
  matchId         String
  bookmakerId     String?
  marketId        String
  selection       String
  decimalOdd      Decimal
  stake           Decimal
  potentialProfit Decimal
  status          BetStatus @default(PENDING)
  profitLoss      Decimal?
  reason          String?
  placedAt        DateTime  @default(now())
  settledAt       DateTime?

  user      User       @relation(fields: [userId], references: [id])
  match     Match      @relation(fields: [matchId], references: [id])
  bookmaker Bookmaker? @relation(fields: [bookmakerId], references: [id])
  market    Market     @relation(fields: [marketId], references: [id])
}

model AiAnalysis {
  id        String   @id @default(uuid())
  matchId   String
  userId    String?
  prompt    String
  response  String
  model     String?
  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id])
  user  User? @relation(fields: [userId], references: [id])
}
